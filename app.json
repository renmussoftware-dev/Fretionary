{
  "expo": {
    "name": "Fretionary",
    "slug": "fretionary",
    "version": "3.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.renmussoftware.nodi",
      "buildNumber": "60",
      "infoPlist": {
        "UIBackgroundModes": [],
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "KHWB32323Q"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.renmussoftware.nodi",
      "versionCode": 10,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "2237808463714897",
          "clientToken": "1c3dee33c98a644a3b9abc7af6260b34",
          "displayName": "Fretionary",
          "scheme": "fb2237808463714897",
          "advertiserIDCollectionEnabled": true,
          "autoLogAppEventsEnabled": true,
          "isAutoInitEnabled": true,
          "iosUserTrackingPermission": "Allow Fretionary to use your activity to help us improve and personalize ads. This helps keep the app free and the Pro tier affordable."
        }
      ]
    ],
    "scheme": "fretionary",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d59b5a1e-aae9-4dd5-9fda-a6ee4949df40"
      }
    }
  }
}
